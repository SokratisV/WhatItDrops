# This repo tracks only the WhatItDrops addons living in this shared AddOns folder.
# Ignore everything at the top level, then re-include our addons.
/*
!/.gitignore
!/LICENSE
!/README.md
!/CHANGELOG.md
!/CONTRIBUTING.md
!/.editorconfig
!/.github/
!/WhatItDrops*/

# Heavy, regenerable build inputs — never shipped, never loaded by the game.
WhatItDrops/tools/cmangos/*.sql
WhatItDrops/tools/cmangos/*.sql.gz
WhatItDrops/tools/lootcodex/*.lua

# OS / editor noise
*.bak
*.tmp
Thumbs.db
.DS_Store
